# ==========================================
# .env — Cau hinh moi truong
# DUNG commit file nay len git!
# ==========================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai-translator

# JWT Secret (doi thanh chuoi random dai)
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars

# OpenAI API Key (lay tai platform.openai.com)
OPENAI_API_KEY=sk-...

# ElevenLabs API Key (lay tai elevenlabs.io)
# Neu chua co thi de trong, se dung OpenAI TTS thay the
ELEVENLABS_API_KEY=

# Port
PORT=3000
